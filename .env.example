DATABASE_URL="postgresql://postgres:postgres@localhost:5432/approval_system?schema=public"
NEXTAUTH_URL="http://192.168.1.216:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
APPROVAL_UPLOAD_DIR="D:/CompanySystem/approval-uploads"
BACKUP_DIR="D:/CompanySystem/backups"
DEMO_MODE="false"
APP_MODE="approval_lite"
NEXT_PUBLIC_VAPID_PUBLIC_KEY="replace-with-vapid-public-key"
VAPID_PRIVATE_KEY="replace-with-vapid-private-key"
VAPID_SUBJECT="mailto:admin@example.com"

# Notification Escalation（通知逾時升級）
ESCALATION_URGENT_MINUTES="15"
ESCALATION_HIGH_MINUTES="60"
ESCALATION_MEDIUM_MINUTES="1440"

# Email Fallback（Email 備援通知）
EMAIL_FALLBACK_ENABLED="false"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
FALLBACK_EMAIL_TO=""

# LINE Fallback（LINE 備援通知，需 LINE Messaging API）
LINE_FALLBACK_ENABLED="false"
LINE_CHANNEL_ACCESS_TOKEN=""
LINE_TARGET_ID=""

# Error Command Center + Codex Auto Repair Intake Sprint 06
GITHUB_AUTO_CREATE_ISSUE="false"
GITHUB_TOKEN=""
GITHUB_REPO_OWNER=""
GITHUB_REPO_NAME=""
CODEX_GITHUB_MENTION="false"
CODEX_INBOX_DIR="C:/CompanySystem/approval-system/CODEX_INBOX"
