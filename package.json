{
  "name": "huangxiang-approval-system",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3000",
    "build": "npm run pre-safe-build && prisma generate && next build",
    "start": "next start -H 0.0.0.0 -p 3000",
    "pre-safe-build": "node scripts/stop-approval-system-processes.cjs",
    "safe-build": "npm run build",
    "safe-dev": "npm run pre-safe-build && npm run dev",
    "safe-start": "npm run pre-safe-build && npm run start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "prisma db seed",
    "notifications:escalate": "tsx scripts/run-notification-escalations.ts",
    "cap:sync": "capacitor sync",
    "cap:open:android": "capacitor open android",
    "backup:run": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/backup-ju-digital-management.ps1"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@prisma/client": "^5.22.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pdfkit": "^0.17.6",
    "@types/web-push": "^3.6.4",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.5.19",
    "next-auth": "^4.24.14",
    "nodemailer": "^9.0.3",
    "pdfkit": "^0.19.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "web-push": "^3.6.7",
    "zod": "^3.24.1"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "uuid": "^11.1.1",
    "glob": "^10.5.0",
    "next-auth": {
      "nodemailer": "^9.0.3"
    }
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.16",
    "postcss": "^8.5.10",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "prisma@5.22.0": true,
    "unrs-resolver@1.12.2": true,
    "@prisma/engines@5.22.0": true,
    "@prisma/client@5.22.0": true
  }
}
